generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Org {
  id                       String            @id @default(cuid())
  name                     String            @unique
  slug                     String            @unique
  logoUrl                  String?
  primaryColor             String            @default("#0A0A12")
  accentColor              String            @default("#00D1FF")
  secondaryColor           String            @default("#E0B130")
  successColor             String            @default("#00FFC2")
  dangerColor              String            @default("#FF4D4D")
  textColor                String            @default("#FFFFFF")
  googleSheetId            String?
  discordBotToken          String?
  discordBotLastSeen       DateTime?
  discordGuildId           String?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  alliedWith               Alliance[]        @relation("AllyAlliances")
  alliances                Alliance[]        @relation("OrgAlliances")
  sentAllianceRequests     AllianceRequest[] @relation("SentAllianceRequests")
  receivedAllianceRequests AllianceRequest[] @relation("ReceivedAllianceRequests")
  distributionLogs         DistributionLog[]
  lootItems                LootItem[]
  lootRequests             LootRequest[]
  lootSessions             LootSession[]
  users                    User[]
  whitelabelConfig         WhitelabelConfig?
}

model Alliance {
  id        String   @id @default(cuid())
  orgId     String
  allyId    String
  createdAt DateTime @default(now())
  ally      Org      @relation("AllyAlliances", fields: [allyId], references: [id], onDelete: Cascade)
  org       Org      @relation("OrgAlliances", fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, allyId])
}

model AllianceRequest {
  id          String   @id @default(cuid())
  senderOrgId String
  targetOrgId String
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sender      Org      @relation("SentAllianceRequests", fields: [senderOrgId], references: [id], onDelete: Cascade)
  target      Org      @relation("ReceivedAllianceRequests", fields: [targetOrgId], references: [id], onDelete: Cascade)

  @@unique([senderOrgId, targetOrgId])
}

model WhitelabelConfig {
  id         String  @id @default(cuid())
  orgId      String  @unique
  themeJson  String?
  footerText String?
  headerText String?
  org        Org     @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model OrgRequest {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  requesterName String
  adminUsername String?
  adminPassword String?  // Will store hashed password or raw depending on implementation, but safer to store hashed
  contactInfo   String
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())
}

model User {
  id                 String                   @id @default(cuid())
  username           String?                  @unique
  password           String?
  email              String?                  @unique
  discordId          String?                  @unique
  name               String?
  image              String?
  emailVerified      DateTime?
  role               Role                     @default(MEMBER)
  status             String                   @default("APPROVED")
  orgId              String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  accounts           Account[]
  distributions      DistributionLog[]
  lootRequests       LootRequest[]
  lootParticipations LootSessionParticipant[]
  sessions           Session[]
  org                Org?                     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  wishlist           WishlistItem[]
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  wikiId    String   // Reference to SCItemCache
  createdAt DateTime @default(now())

  @@unique([userId, wikiId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model LootItem {
  id            String   @id @default(cuid())
  orgId         String
  name          String
  category      String
  subCategory   String?
  quantity      Int      @default(1)
  size          String?
  class         String?
  grade         String?
  manufacturer  String?
  source        String?
  lastUpdatedBy String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  org           Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([category])
}

model SCItemCache {
  id           String   @id @default(cuid())
  wikiId       String   @unique
  name         String   @unique
  type         String
  subType      String?
  manufacturer String?
  size         String?
  grade        String?
  class        String?
  description  String?
  imageUrl     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([type])
}

model DistributionLog {
  id          String   @id @default(cuid())
  orgId       String?
  recipientId String?
  itemName    String
  quantity    Int
  type        String
  method      String
  performedBy String?
  timestamp   DateTime @default(now())
  org         Org?     @relation(fields: [orgId], references: [id], onDelete: SetNull)
  recipient   User?    @relation(fields: [recipientId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([recipientId])
  @@index([type])
  @@index([timestamp])
}

model LootRequest {
  id           String   @id @default(cuid())
  orgId        String
  targetOrgId  String?
  userId       String
  itemId       String
  itemName     String
  category     String
  quantity     Int      @default(1)
  status       String   @default("PENDING")
  denialReason String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  org          Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([userId])
  @@index([status])
}

model LootSession {
  id           String                   @id @default(cuid())
  orgId        String?
  title        String
  status       String                   @default("ACTIVE") // ACTIVE, SPINNING, COMPLETED, ARCHIVED
  type         String                   @default("REEL")   // REEL, WHEEL
  mode         String                   @default("OPERATORS") // OPERATORS, ITEMS
  
  // Real-time HUD fields
  animationState String?                // JSON string of current spin state
  currentWinnerId String?               // ID of the user who won (if determined)
  
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  org          Org?                     @relation(fields: [orgId], references: [id], onDelete: SetNull)
  items        LootSessionItem[]
  participants LootSessionParticipant[]

  @@index([orgId])
  @@index([status])
}

model LootSessionItem {
  id        String      @id @default(cuid())
  sessionId String
  itemId    String
  name      String
  category  String
  imageUrl  String?
  rarity    String      @default("COMMON")
  session   LootSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model LootSessionParticipant {
  id          String      @id @default(cuid())
  sessionId   String
  userId      String
  openedAt    DateTime?
  wonItemName String?
  session     LootSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
}

enum Role {
  MEMBER
  ADMIN
  SUPERADMIN
}
